# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localbridge:localbridge123@localhost:5432/localbridge_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d

# OTP (dev mode — OTP prints to console, no SMS sent)
OTP_EXPIRY_MINUTES=5
DEV_MODE_OTP=true

# Twilio (fill in Day 5)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase (fill in Day 8)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Cloudinary (fill in Day 3)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
